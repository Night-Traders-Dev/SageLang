
#
# Compiler & Build
#
CONFIG_CC_GCC=y
# CONFIG_CC_CLANG is not set
# CONFIG_CC_SYSTEM is not set
CONFIG_BUILD_MAKE=y
# CONFIG_BUILD_CMAKE is not set

#
# Self-Hosted Sage Compiler
#
CONFIG_SELFHOST=y
CONFIG_SELFHOST_EMIT_C=y
CONFIG_SELFHOST_EMIT_LLVM=y
CONFIG_SELFHOST_EMIT_ASM=y
CONFIG_SELFHOST_TOOLS=y
CONFIG_SELFHOST_RUN_TESTS=y
# end of Self-Hosted Sage Compiler

#
# LLVM Backend
#
CONFIG_LLVM_BACKEND=y
CONFIG_LLVM_RUNTIME=y
CONFIG_LLVM_COMPILE=y
# end of LLVM Backend

#
# Native Code Generation
#
CONFIG_NATIVE_CODEGEN=y
CONFIG_NATIVE_TARGET_HOST=y
# CONFIG_NATIVE_TARGET_X86_64 is not set
# CONFIG_NATIVE_TARGET_AARCH64 is not set
# CONFIG_NATIVE_TARGET_RV64 is not set
# end of Native Code Generation

# CONFIG_OPT_O0 is not set
# CONFIG_OPT_O1 is not set
# CONFIG_OPT_O2 is not set
CONFIG_OPT_O3=y
# CONFIG_DEBUG is not set
# end of Compiler & Build

#
# GPU & Graphics
#
CONFIG_VULKAN=y
CONFIG_GLFW=y
CONFIG_GPU_PLATFORM_AUTO=y
# CONFIG_GPU_PLATFORM_X11 is not set
# CONFIG_GPU_PLATFORM_WAYLAND is not set
CONFIG_COMPILE_SHADERS=y
# end of GPU & Graphics

#
# Networking
#
CONFIG_CURL=y
CONFIG_OPENSSL=y
# end of Networking

#
# Platform & Cross-compilation
#
# CONFIG_PICO_BUILD is not set
CONFIG_TARGET_HOST=y
# CONFIG_TARGET_X86_64 is not set
# CONFIG_TARGET_AARCH64 is not set
# CONFIG_TARGET_RV64 is not set
# end of Platform & Cross-compilation

#
# Testing
#
CONFIG_RUN_TESTS=y
CONFIG_TEST_INTERPRETER=y
CONFIG_TEST_SELFHOST=y
CONFIG_TEST_GPU=y
# CONFIG_TEST_SCREENSHOTS is not set
# end of Testing

#
# Installation
#
CONFIG_INSTALL_PREFIX="/usr/local"
CONFIG_INSTALL_LIBS=y
CONFIG_INSTALL_LSP=y
# end of Installation

#
# Advanced
#
CONFIG_THREADING=y
CONFIG_GC_ENABLED=y
CONFIG_VERBOSE_BUILD=y
# end of Advanced
