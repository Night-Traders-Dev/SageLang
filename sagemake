#!/usr/bin/env python3
"""
SageLang Unified Build System (sagemake)
Modern, visually appealing build & install orchestrator using 'rich'.
"""

import os
import sys
import subprocess
import argparse
import time
import shutil
import re
from pathlib import Path
from rich.console import Console
from rich.panel import Panel
from rich.table import Table
from rich.progress import Progress, SpinnerColumn, TextColumn, BarColumn, TimeElapsedColumn
from rich.status import Status
from rich.text import Text
from rich import box

# Configuration
VERSION = "0.0.0"
if Path("VERSION").exists():
    VERSION = Path("VERSION").read_text().strip()
elif Path("core/VERSION").exists():
    VERSION = Path("core/VERSION").read_text().strip()

console = Console()

def banner(title):
    console.print(Panel(Text(title, style="bold cyan", justify="center"), border_style="cyan", box=box.ROUNDED))

def section(title):
    console.print(f"\n [bold cyan]→[/bold cyan] [bold]{title}[/bold]")

def step(message):
    console.print(f"  [yellow]⚙[/yellow] {message: <45}", end="")

def step_ok(detail="done"):
    console.print(f" [bold green]✓[/bold green] [green]done[/green] [dim]({detail})[/dim]")

def step_warn(detail):
    console.print(f" [bold yellow]![/bold yellow] [yellow]{detail}[/yellow]")

def step_fail(detail="failed"):
    console.print(f" [bold red]✗[/bold red] [red]{detail}[/red]")
    sys.exit(1)

def run_cmd(cmd, cwd=None, capture_output=True, shell=False):
    try:
        if shell:
            result = subprocess.run(cmd, cwd=cwd, capture_output=capture_output, text=True, shell=True)
        else:
            result = subprocess.run(cmd, cwd=cwd, capture_output=capture_output, text=True)
        return result
    except Exception as e:
        return None

def check_dependencies(args):
    section("Checking dependencies")
    table = Table(box=box.SIMPLE, show_header=True, header_style="bold magenta")
    table.add_column("Dependency")
    table.add_column("Status")
    table.add_column("Version")

    missing_critical = False
    
    deps = [
        ("C compiler (gcc)", "gcc"),
        ("Make", "make"),
        ("CMake", "cmake"),
        ("GLSL compiler (glslc)", "glslc"),
        ("Vulkan SDK", "pkg-config --exists vulkan"),
        ("GLFW", "pkg-config --exists glfw3"),
        ("libcurl", "pkg-config --exists libcurl"),
        ("OpenSSL", "pkg-config --exists openssl"),
    ]

    found_deps = {}

    for name, cmd in deps:
        if "pkg-config" in cmd:
            res = run_cmd(cmd, shell=True)
            if res and res.returncode == 0:
                pkg = cmd.split()[-1]
                ver_res = run_cmd(f"pkg-config --modversion {pkg}", shell=True)
                ver = ver_res.stdout.strip() if ver_res else "unknown"
                table.add_row(name, "[green]✓ found[/green]", ver)
                found_deps[name] = True
            else:
                table.add_row(name, "[yellow]! missing[/yellow]", "N/A")
                found_deps[name] = False
        else:
            res = run_cmd([cmd, "--version"])
            if res and res.returncode == 0:
                ver = res.stdout.split('\n')[0].replace(f"{cmd} ", "").split()[-1] if res.stdout else "unknown"
                table.add_row(name, "[green]✓ found[/green]", ver)
                found_deps[name] = True
            else:
                if cmd in ["gcc", "make"]:
                    table.add_row(name, "[red]✗ missing[/red]", "CRITICAL")
                    missing_critical = True
                else:
                    table.add_row(name, "[yellow]! missing[/yellow]", "N/A")
                found_deps[name] = False

    console.print(table)
    if missing_critical:
        step_fail("Missing required dependencies (gcc/make).")
    return found_deps

def prepare_workspace():
    section("Preparing workspace")
    
    step("Updating submodules")
    if Path(".git").exists():
        run_cmd(["git", "submodule", "sync"])
        run_cmd(["git", "submodule", "update", "--init"])
        step_ok("initialized")
    else:
        step_ok("skipped (not a git repo)")

    step("Removing old build artifacts")
    if Path("core/build_sage").exists():
        shutil.rmtree("core/build_sage")
    run_cmd(["make", "-C", "core", "clean"])
    # git clean -fdx is dangerous to run blindly from a script without user prompt usually
    # but build.sh did it. I'll skip it for safety unless requested? 
    # Actually, let's stick to what build.sh did but maybe just build artifacts.
    step_ok("clean")

def compile_shaders(found_deps):
    if found_deps.get("GLSL compiler (glslc)") and Path("core/examples/shaders").exists():
        section("Compiling GLSL shaders to SPIR-V")
        step("Compiling shaders")
        shaders = list(Path("core/examples/shaders").glob("*.vert")) + \
                  list(Path("core/examples/shaders").glob("*.frag")) + \
                  list(Path("core/examples/shaders").glob("*.comp"))
        
        count = 0
        fail = 0
        for s in shaders:
            res = run_cmd(["glslc", str(s), "-o", f"{s}.spv"])
            if res and res.returncode == 0:
                count += 1
            else:
                fail += 1
        
        if fail == 0:
            step_ok(f"{count} modules")
        else:
            step_warn(f"{count} ok, {fail} failed")

def build_sage(args, found_deps):
    use_cmake = found_deps.get("CMake") and not args.make_only
    
    if not use_cmake:
        section("Building with Make")
        step("Compiling sage (C sources)")
        start = time.time()
        res = run_cmd(["make", "-C", "core", "-j" + str(os.cpu_count() or 2)], capture_output=False)
        if res and res.returncode == 0:
            elapsed = int(time.time() - start)
            step_ok(f"{elapsed}s")
        else:
            step_fail("compilation failed")
        return Path("core/sage"), Path("core/sage-lsp")
    else:
        section("Configuring CMake (self-hosted Sage mode)")
        step("Running cmake -DBUILD_SAGE=ON")
        build_dir = Path("core/build_sage")
        build_dir.mkdir(exist_ok=True)
        res = run_cmd(["cmake", "-DBUILD_SAGE=ON", ".."], cwd=build_dir)
        if res and res.returncode == 0:
            step_ok(f"v{VERSION}")
        else:
            step_fail("CMake configuration failed")
            
        section("Building C host interpreter")
        step("Compiling sage (C sources)")
        start = time.time()
        res = run_cmd(["make", "-j" + str(os.cpu_count() or 2), "sage"], cwd=build_dir, capture_output=False)
        if res and res.returncode == 0:
            elapsed = int(time.time() - start)
            step_ok(f"{elapsed}s")
        else:
            step_fail("compilation failed")
            
        return build_dir / "sage", build_dir / "sage-lsp"

def verify_binaries(sage_bin, lsp_bin):
    step("Verifying binary")
    if sage_bin.exists() and os.access(sage_bin, os.X_OK):
        size = run_cmd(["du", "-h", str(sage_bin)]).stdout.split()[0]
        step_ok(f"{sage_bin} ({size})")
    else:
        step_fail(f"binary not found or not executable: {sage_bin}")

def run_tests(args, sage_bin):
    if args.skip_tests:
        console.print("\n [dim]Tests skipped (--skip-tests)[/dim]")
        return

    banner("Test Suite")
    
    # Sync sage bin to root if needed (tests/run_tests.sh expects it)
    if sage_bin.absolute() != Path("sage").absolute():
        shutil.copy(sage_bin, "sage")
        os.chmod("sage", 0o755)

    section("C Interpreter Tests")
    step("Interpreter tests (241)")
    res = run_cmd(["bash", "core/tests/run_tests.sh"], shell=False)
    if res and res.returncode == 0:
        pass_match = re.search(r'(\d+) passed', res.stdout)
        pass_count = pass_match.group(1) if pass_match else "unknown"
        step_ok(f"{pass_count} passed")
    else:
        step_warn("failed")
        console.print(res.stdout[-500:] if res else "No output")

    section("Self-Hosted Tests")
    step("Full self-hosted suite")
    res = run_cmd(["make", "-C", "core", "test-selfhost"], capture_output=False)
    if res and res.returncode == 0:
        step_ok("all suites passed")
    else:
        step_warn("some tests failed")

def perform_install(args):
    if not args.install:
        console.print(f"\n [dim]To install: python3 sagemake.py --install[/dim]")
        return

    banner("Installation")
    section("Building release binary for installation")
    step("Compiling sage via Make (release)")
    res = run_cmd(["make", "-C", "core", "-j" + str(os.cpu_count() or 2)], capture_output=False)
    if res and res.returncode == 0:
        step_ok("sage + sage-lsp")
    else:
        step_fail("Make build failed")

    section("Installing SageLang system-wide")
    console.print("  [yellow]⚙[/yellow] [bold]Installing to /usr/local[/bold]")
    res = run_cmd(["sudo", "make", "-C", "core", "install"], capture_output=False)
    if res and res.returncode == 0:
        console.print("  [bold green]✓[/bold green] [green]Installed to /usr/local/bin/sage[/green]")
    else:
        step_fail("Installation failed (sudo required)")

def fix_permissions():
    sudo_user = os.environ.get("SUDO_USER")
    if sudo_user:
        run_cmd(["chown", "-R", sudo_user, "."])
        console.print(f"\n [bold green]✓[/bold green] [green]Restored workspace ownership to {sudo_user}[/green]\n")

def build_trainer(args):
    if not args.train:
        return
    section("Building SL-TQ-LLM C Trainer")
    flags = ""
    libs = "-lm -lpthread"
    
    # Auto-detect cuBLAS
    if Path("/usr/include/cublas_v2.h").exists() or run_cmd("pkg-config --exists cublas", shell=True).returncode == 0:
        flags += " -DUSE_CUBLAS"
        libs += " -lcublas -lcudart"
        console.print("    [bold green]✓[/bold green] cuBLAS GPU acceleration")
    else:
        console.print("    [dim]  cuBLAS not found (CPU only)[/dim]")

    if os.uname().machine == "aarch64":
        flags += " -DUSE_NEON"
        console.print("    [bold green]✓[/bold green] ARM NEON SIMD")

    cmd = f"gcc -O3 -march=native {flags} -o train_sl_tq core/src/c/train_sl_tq.c {libs}"
    res = run_cmd(cmd, shell=True, capture_output=False)
    if res and res.returncode == 0:
        console.print("    [bold green]✓[/bold green] Built: train_sl_tq")
    else:
        console.print("    [bold red]✗[/bold red] Trainer build failed")

def build_chatbot(args, sage_bin):
    if not args.chatbot:
        return
    section("Compiling Chatbots")
    
    # SageLLM chatbot via C backend
    console.print("    [cyan]→[/cyan] Compiling sagellm_chatbot via C backend...")
    res = run_cmd([str(sage_bin), "--compile", "core/models/chatbots/sagellm_chatbot.sage", "-o", "sagellm_chat_c"], capture_output=False)
    if res and res.returncode == 0:
        console.print("    [bold green]✓[/bold green] sagellm_chat_c (C backend)")
    else:
        console.print("    [bold red]✗[/bold red] C backend compilation failed")

    # SageLLM chatbot via LLVM backend
    console.print("    [cyan]→[/cyan] Compiling sagellm_chatbot via LLVM backend...")
    res = run_cmd([str(sage_bin), "--compile-llvm", "core/models/chatbots/sagellm_chatbot.sage", "-o", "sagellm_chat"], capture_output=False)
    if res and res.returncode == 0:
        console.print("    [bold green]✓[/bold green] sagellm_chat (LLVM backend)")
    else:
        console.print("    [bold red]✗[/bold red] LLVM backend compilation failed")

def main():
    parser = argparse.ArgumentParser(description="SageLang Unified Build System")
    parser.add_argument("subcommand", nargs="?", help="Subcommand (all, build, train, chatbot)")
    parser.add_argument("--install", action="store_true", help="Install to /usr/local after building")
    parser.add_argument("--skip-tests", action="store_true", help="Skip test suite")
    parser.add_argument("--make-only", action="store_true", help="Use Make instead of CMake")
    parser.add_argument("--train", action="store_true", help="Build the SL-TQ-LLM C trainer")
    parser.add_argument("--chatbot", action="store_true", help="Compile chatbots (C + LLVM backends)")
    parser.add_argument("--no-vulkan", action="store_true", help="Disable Vulkan GPU support")
    parser.add_argument("--no-glfw", action="store_true", help="Disable GLFW windowed mode")
    parser.add_argument("--no-curl", action="store_true", help="Disable HTTP/libcurl support")
    parser.add_argument("--no-ssl", action="store_true", help="Disable OpenSSL support")
    parser.add_argument("--no-gpu", action="store_true", help="Disable all GPU features (Vulkan + GLFW)")
    parser.add_argument("--minimal", action="store_true", help="Disable all optional features (core only)")
    args = parser.parse_args()

    if args.subcommand == "all":
        args.train = args.chatbot = True
    elif args.subcommand == "train":
        args.train = True
    elif args.subcommand == "chatbot":
        args.chatbot = True
    elif args.subcommand == "install":
        args.install = True

    if args.minimal:
        args.no_vulkan = args.no_glfw = args.no_curl = args.no_ssl = args.no_gpu = True

    banner(f"SageLang Build Pipeline v{VERSION}")

    found_deps = check_dependencies(args)
    prepare_workspace()
    compile_shaders(found_deps)
    
    sage_bin, lsp_bin = build_sage(args, found_deps)
    verify_binaries(sage_bin, lsp_bin)
    
    # PDF generation (omitted for brevity in first draft but can be added)
    
    run_tests(args, sage_bin)
    perform_install(args)
    
    build_trainer(args)
    build_chatbot(args, sage_bin)
    
    fix_permissions()
    
    banner("Build Complete")

if __name__ == "__main__":
    main()
