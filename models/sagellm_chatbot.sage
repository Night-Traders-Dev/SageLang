# Semantic router for fast keyword dispatch
proc route_fast(query):
    let lp = to_lower(query)
    # Version/help/status — instant answers, no reasoning needed
    if contains(lp, "version"):
        return "SageLLM v2.0.0 | SageGPT-Medium (344544 params, 2 layers) | Sage 1.0.0"
    if contains(lp, "help") and not contains(lp, "how"):
        return "Commands: quit, memory, think <q>, plan <goal>, stats, history, search <q>" + chr(10) + "Topics: loops, imports, classes, GC, compiler, data, functions, errors, testing, concurrency, LLM, agents, crypto, networking, GPU, ML, OS, regex, planning"
    if lp == "stats":
        return engram.summary(memory)
    return nil

# Chain-of-thought reasoning engine
proc reason(question):
    let chain = {}
    chain["steps"] = []
    chain["conclusion"] = ""
    let lp = to_lower(question)

    # Step 1: Check semantic router
    let fast = route_fast(question)
    if fast != nil:
        push(chain["steps"], {"type": "route", "content": "Fast dispatch via semantic router"})
        chain["conclusion"] = fast
        return chain

    # Step 2: Recall from Engram memory
    let mem_results = engram.recall(memory, lp, 5)
    if len(mem_results) > 0:
        let mem_text = ""
        for i in range(len(mem_results)):
            mem_text = mem_text + mem_results[i]["entry"]["content"]
            if i < len(mem_results) - 1:
                mem_text = mem_text + "; "
        push(chain["steps"], {"type": "recall", "content": "Memory: " + mem_text})
    else:
        push(chain["steps"], {"type": "recall", "content": "No specific memory match, using general knowledge"})

    # Step 3: Classify topic
    let topic = "general"
    if contains(lp, "llm") or contains(lp, "language model") or contains(lp, "transformer") or contains(lp, "tokeniz") or contains(lp, "attention") or contains(lp, "lora") or contains(lp, "engram") or contains(lp, "neural") or contains(lp, "gguf") or contains(lp, "dpo") or contains(lp, "rag"):
        topic = "llm"
    if contains(lp, "agent") or contains(lp, "react") or contains(lp, "tool use") or contains(lp, "autonomous") or contains(lp, "supervisor") or contains(lp, "worker") or contains(lp, "critic"):
        topic = "agent_framework"
    if contains(lp, "chatbot") or contains(lp, "chat bot") or contains(lp, "persona") or contains(lp, "conversation") or contains(lp, "intent"):
        topic = "chatbot"
    if contains(lp, "crypto") or contains(lp, "sha") or contains(lp, "hash") or contains(lp, "encrypt") or contains(lp, "base64") or contains(lp, "hmac") or contains(lp, "cipher"):
        topic = "crypto"
    if contains(lp, "network") or contains(lp, "http") or contains(lp, "socket") or contains(lp, "url") or contains(lp, "dns") or contains(lp, "websocket") or contains(lp, "tcp"):
        topic = "networking"
    if contains(lp, "baremetal") or contains(lp, "uefi") or contains(lp, "kernel") or contains(lp, "elf") or contains(lp, "pci") or contains(lp, "acpi") or contains(lp, "osdev") or contains(lp, "fat") or contains(lp, "paging"):
        topic = "osdev"
    if contains(lp, "tensor") or contains(lp, "machine learn") or contains(lp, "neural net") or contains(lp, "optimizer") or contains(lp, "gradient") or contains(lp, "matmul"):
        topic = "ml"
    if contains(lp, "regex") or contains(lp, "regular exp") or contains(lp, "pattern match"):
        topic = "regex"
    if contains(lp, "gpu") or contains(lp, "vulkan") or contains(lp, "opengl") or contains(lp, "shader") or contains(lp, "render") or contains(lp, "pbr") or contains(lp, "mesh"):
        topic = "graphics"
    if topic == "general":
        if contains(lp, "for") or contains(lp, "loop") or contains(lp, "while") or contains(lp, "iteration") or contains(lp, "range"):
            topic = "loops"
    if topic == "general":
        if contains(lp, "import") or contains(lp, "module") or contains(lp, "library") or contains(lp, "package"):
            topic = "modules"
    if topic == "general":
        if contains(lp, "class") or contains(lp, "object") or contains(lp, "inherit") or contains(lp, "method"):
            topic = "oop"
    if topic == "general":
        if contains(lp, "gc") or contains(lp, "garbage") or contains(lp, "collector") or contains(lp, "memory leak"):
            topic = "gc"
    if topic == "general":
        if contains(lp, "compile") or contains(lp, "backend") or contains(lp, "emit") or contains(lp, "codegen"):
            topic = "compiler"
    if topic == "general":
        if contains(lp, "array") or contains(lp, "dict") or contains(lp, "list") or contains(lp, "data struct") or contains(lp, "tuple"):
            topic = "data"
    if topic == "general":
        if contains(lp, "function") or contains(lp, "proc") or contains(lp, "closure") or contains(lp, "return"):
            topic = "functions"
    if topic == "general":
        if contains(lp, "error") or contains(lp, "exception") or contains(lp, "try") or contains(lp, "catch") or contains(lp, "raise"):
            topic = "errors"
    if topic == "general":
        if contains(lp, "test") or contains(lp, "debug") or contains(lp, "fix") or contains(lp, "bug") or contains(lp, "assert"):
            topic = "testing"
    if topic == "general":
        if contains(lp, "thread") or contains(lp, "async") or contains(lp, "channel") or contains(lp, "concurrent") or contains(lp, "atomic") or contains(lp, "mutex"):
            topic = "concurrency"
    if topic == "general":
        if contains(lp, "plan") or contains(lp, "how to build") or contains(lp, "steps") or contains(lp, "roadmap"):
            topic = "planning"
    if topic == "general":
        if contains(lp, "syntax") or contains(lp, "indent") or contains(lp, "keyword"):
            topic = "syntax"
    if topic == "general":
        if contains(lp, "string") or contains(lp, "text") or contains(lp, "concat") or contains(lp, "split") or contains(lp, "format"):
            topic = "string"
    if topic == "general":
        if contains(lp, "file") or contains(lp, "read") or contains(lp, "write") or contains(lp, "print") or contains(lp, "input") or contains(lp, "stdin"):
            topic = "io"
    push(chain["steps"], {"type": "classify", "content": "Topic: " + topic})

    # Step 4: Generate answer
    let answer = ""
    if topic == "llm":
        answer = "The Sage LLM library (lib/llm/, 15 modules) for building language models:" + chr(10) + chr(10) + "  import llm.config        # Configs: tiny (1M) to llama_13b (13B)" + chr(10) + "  import llm.tokenizer      # BPE, character, and word tokenizers" + chr(10) + "  import llm.embedding      # Token + positional (sinusoidal, learned, RoPE)" + chr(10) + "  import llm.attention      # Multi-head self-attention, KV cache, causal mask" + chr(10) + "  import llm.transformer    # Full blocks: LayerNorm, RMSNorm, FFN, SwiGLU" + chr(10) + "  import llm.generate       # Greedy, top-k, top-p, beam search, repetition penalty" + chr(10) + "  import llm.train          # Training loops, cosine/linear/constant LR, perplexity" + chr(10) + "  import llm.lora           # Low-rank adapters (rank, alpha, A/B matrices)" + chr(10) + "  import llm.quantize       # Int8/int4 compression with error analysis" + chr(10) + "  import llm.engram         # 4-tier memory (working/episodic/semantic/procedural)" + chr(10) + "  import llm.rag            # Document store, keyword retrieval, context building" + chr(10) + "  import llm.dpo            # Direct Preference Optimization, ORPO, reward models" + chr(10) + "  import llm.prompt         # ChatML, Llama, Alpaca formats, few-shot templates" + chr(10) + "  import llm.gguf           # GGUF v3 export for Ollama/llama.cpp" + chr(10) + "  import llm.agent          # Tool use, CoT reasoning, memory integration" + chr(10) + chr(10) + "Plus ml_native C backend: matmul, softmax, cross_entropy, adam_update, rms_norm, silu (~12 GFLOPS)."
    if topic == "agent_framework":
        answer = "Sage agent framework (lib/agent/, 12 modules) for autonomous AI:" + chr(10) + chr(10) + "  import agent.core           # ReAct loop: observe -> think -> act -> reflect" + chr(10) + "  import agent.tools          # File I/O, code analysis, search, system tools" + chr(10) + "  import agent.planner        # Task decomposition with dependency DAG" + chr(10) + "  import agent.router         # Multi-agent orchestrator, capability routing" + chr(10) + "  import agent.supervisor     # Supervisor-Worker pattern, workflow execution" + chr(10) + "  import agent.critic         # Rule validators + LLM critics, verify loops" + chr(10) + "  import agent.schema         # Typed tool parameters, validation, defaults" + chr(10) + "  import agent.trace          # SFT training data from execution recordings" + chr(10) + "  import agent.grammar        # Grammar-constrained: tool calls, JSON, Sage code" + chr(10) + "  import agent.sandbox        # Code extraction, safety checking, math eval" + chr(10) + "  import agent.tot            # Tree of Thoughts: BFS/best-first search" + chr(10) + "  import agent.semantic_router # Keyword-based fast dispatch (no LLM needed)"
    if topic == "chatbot":
        answer = "Sage chatbot framework (lib/chat/, 3 modules):" + chr(10) + chr(10) + "  import chat.bot      # Conversation engine, intents, middleware, LLM integration" + chr(10) + "  import chat.session   # Multi-session store, history, text/JSON export" + chr(10) + "  import chat.persona   # 6 built-in personas:" + chr(10) + "    sage_developer()   - Expert Sage coder" + chr(10) + "    code_reviewer()    - Quality-focused reviewer" + chr(10) + "    teacher()          - Patient explainer" + chr(10) + "    debugger()         - Systematic bug finder" + chr(10) + "    architect()        - System design expert" + chr(10) + "    assistant()        - General-purpose helper" + chr(10) + chr(10) + "Usage:" + chr(10) + "  let b = bot.create(name, greeting, llm_fn)" + chr(10) + "  persona.apply_persona(b, persona.sage_developer())" + chr(10) + "  bot.add_intent(b, name, keywords, handler)" + chr(10) + "  let resp = bot.respond(b, user_message)"
    if topic == "crypto":
        answer = "Sage crypto library (lib/crypto/, 6 modules):" + chr(10) + chr(10) + "  import crypto.hash     # SHA-256, SHA-1, CRC-32" + chr(10) + "  import crypto.hmac     # HMAC with pluggable hash, constant-time compare" + chr(10) + "  import crypto.encoding # Base64 (standard + URL-safe), hex encode/decode" + chr(10) + "  import crypto.cipher   # XOR stream, RC4, PKCS7 padding, CBC/CTR modes" + chr(10) + "  import crypto.rand     # xoshiro256** PRNG, UUID v4, secure shuffle" + chr(10) + "  import crypto.password # PBKDF2-HMAC key derivation, password hash/verify"
    if topic == "networking":
        answer = "Sage networking (native modules + lib/net/, 8 modules):" + chr(10) + chr(10) + "  Native: import socket, tcp, http (libcurl), ssl (OpenSSL)" + chr(10) + chr(10) + "  import net.url         # URL parse/build, percent encoding, query strings" + chr(10) + "  import net.headers     # HTTP header parse/build, content-type" + chr(10) + "  import net.request     # HTTP client builder, auth, response helpers" + chr(10) + "  import net.server      # TCP/HTTP server, routing, response builders" + chr(10) + "  import net.websocket   # WebSocket frames (RFC 6455), upgrade" + chr(10) + "  import net.mime        # 80+ MIME types from file extensions" + chr(10) + "  import net.dns         # DNS wire-format parse/build" + chr(10) + "  import net.ip          # IPv4, CIDR, private/loopback/multicast"
    if topic == "osdev":
        answer = "Sage OS/baremetal library (lib/os/, 15 modules):" + chr(10) + chr(10) + "  import os.fat / os.fat_dir   # FAT filesystem + directory traversal" + chr(10) + "  import os.elf / os.pe        # ELF + PE/COFF binary parsers" + chr(10) + "  import os.mbr / os.gpt       # Partition table parsers" + chr(10) + "  import os.pci / os.acpi      # Hardware enumeration" + chr(10) + "  import os.uefi               # EFI memory map, RSDP, config tables" + chr(10) + "  import os.paging / os.idt    # 4-level page tables, interrupt descriptors" + chr(10) + "  import os.serial             # UART/COM port for debug output" + chr(10) + "  import os.dtb                # Device tree for ARM64/RISC-V" + chr(10) + "  import os.alloc / os.vfs     # Kernel allocators, virtual filesystem"
    if topic == "ml":
        answer = "Sage ML libraries (lib/ml/ 8 modules + lib/cuda/ 4 modules + ml_native):" + chr(10) + chr(10) + "  import ml.tensor    # N-dim tensors, matmul, activations, softmax" + chr(10) + "  import ml.nn         # Linear, ReLU, Sigmoid, Dropout, Sequential" + chr(10) + "  import ml.optim      # SGD (momentum), Adam, LR schedulers" + chr(10) + "  import ml.loss       # MSE, cross-entropy, Huber, L1, KL divergence" + chr(10) + "  import ml.data       # Dataset, DataLoader, normalization, train/test split" + chr(10) + "  import ml.debug      # Weight stats, histograms, training diagnostics" + chr(10) + "  import ml.viz        # SVG charts: loss curves, attention heatmaps, architecture" + chr(10) + "  import ml.monitor    # Live training progress tracking" + chr(10) + chr(10) + "Native backend (ml_native): C-optimized matmul, softmax, RMSNorm, SiLU, Adam." + chr(10) + "12+ GFLOPS on 64x64 matmul. Use for all performance-critical operations."
    if topic == "regex":
        answer = "Sage regex engine (import std.regex):" + chr(10) + chr(10) + "  regex.test(pattern, text)           # boolean match" + chr(10) + "  regex.search(pattern, text)         # first match {start, end, text}" + chr(10) + "  regex.find_all(pattern, text)       # all matches" + chr(10) + "  regex.replace_all(pattern, text, r) # replace" + chr(10) + "  regex.split_by(pattern, text)       # split by pattern" + chr(10) + chr(10) + "Supports: . * + ? [] [^] ^ $ | and character classes."
    if topic == "graphics":
        answer = "Sage GPU engine (lib/graphics/, 24 modules + native Vulkan/OpenGL):" + chr(10) + chr(10) + "  import gpu                  # Native C backend (100+ sgpu_* functions)" + chr(10) + "  import graphics.vulkan      # Builder API helpers" + chr(10) + "  import graphics.opengl      # OpenGL 4.5 drop-in alternative" + chr(10) + "  import graphics.math3d      # vec2/3/4, mat4, camera, projection, quaternions" + chr(10) + "  import graphics.mesh        # Procedural geometry, OBJ/glTF loading" + chr(10) + "  import graphics.renderer    # Frame loop, depth buffer, sync primitives" + chr(10) + "  import graphics.pbr         # Cook-Torrance PBR, metallic-roughness materials" + chr(10) + "  import graphics.shadows     # Shadow maps, cascade shadows, depth passes" + chr(10) + "  import graphics.deferred    # G-buffer (4 MRT), SSAO, SSR" + chr(10) + "  import graphics.taa         # Temporal anti-aliasing, Halton jitter" + chr(10) + "  + postprocess, scene, material, ui, debug_ui, and more"
    if topic == "loops":
        answer = "Sage loops:" + chr(10) + "  # For with range" + chr(10) + "  for i in range(10):" + chr(10) + "      print i" + chr(10) + chr(10) + "  # For over array" + chr(10) + "  for item in my_array:" + chr(10) + "      print item" + chr(10) + chr(10) + "  # While" + chr(10) + "  while condition:" + chr(10) + "      do_work()" + chr(10) + chr(10) + "  break/continue work as expected." + chr(10) + "  WARNING: elif inside for loops with break can malfunction. Use if/continue instead."
    if topic == "modules":
        answer = "Sage has 127+ modules in 11 categories with dotted imports:" + chr(10) + "  import os.fat        # OS/baremetal (15 modules)" + chr(10) + "  import net.url       # Networking (8 modules)" + chr(10) + "  import crypto.hash   # Cryptography (6 modules)" + chr(10) + "  import std.regex     # Standard lib (23 modules)" + chr(10) + "  import ml.tensor     # Machine learning (8 modules)" + chr(10) + "  import llm.agent     # LLM/AI (15 modules)" + chr(10) + "  import agent.core    # Agent framework (12 modules)" + chr(10) + "  import chat.bot      # Chat (3 modules)" + chr(10) + "  import graphics.pbr  # Graphics (24 modules)" + chr(10) + chr(10) + "Last path component becomes the binding: import os.fat -> fat.method()"
    if topic == "oop":
        answer = "Sage OOP:" + chr(10) + "  class Animal:" + chr(10) + "      proc init(self, name):" + chr(10) + "          self.name = name" + chr(10) + "      proc speak(self):" + chr(10) + "          return self.name + says hello" + chr(10) + chr(10) + "  class Dog(Animal):  # inheritance" + chr(10) + "      proc speak(self):" + chr(10) + "          return self.name + barks" + chr(10) + chr(10) + "  let d = Dog(Buddy)" + chr(10) + "  print d.speak()" + chr(10) + chr(10) + "  NOTE: Instance == always returns false. Use field comparison." + chr(10) + "  NOTE: Class methods cannot see module-level let vars."
    if topic == "gc":
        answer = "Sage concurrent tri-color mark-sweep GC:" + chr(10) + "  Phase 1 (STW ~50-200us): Root scan, shade gray, enable write barrier" + chr(10) + "  Phase 2 (concurrent):   Process gray objects from mark stack" + chr(10) + "  Phase 3 (STW ~20-50us): Remark, drain barrier-shaded objects" + chr(10) + "  Phase 4 (concurrent):   Sweep white objects in batches" + chr(10) + chr(10) + "  Colors: WHITE (unreached), GRAY (reached), BLACK (scanned)" + chr(10) + "  SATB write barrier prevents missed objects." + chr(10) + "  Control: gc_collect(), gc_enable(), gc_disable()" + chr(10) + "  Barriers in: env.c (define/assign), value.c (array_set/dict_set)"
    if topic == "compiler":
        answer = "Sage has 3 compiler backends:" + chr(10) + "  sage --emit-c file.sage           # C source output" + chr(10) + "  sage --compile file.sage          # Compile to binary via C (gcc/clang)" + chr(10) + "  sage --emit-llvm file.sage        # LLVM IR output" + chr(10) + "  sage --compile-llvm file.sage     # Native via LLVM (clang)" + chr(10) + "  sage --emit-asm file.sage         # Direct assembly (x86-64/aarch64/rv64)" + chr(10) + "  sage --compile-native file.sage   # Native binary from asm" + chr(10) + chr(10) + "  Use --target x86-64|aarch64|rv64 for cross-compilation." + chr(10) + "  Optimization: -O0 to -O3 (constfold, DCE, inlining)."
    if topic == "data":
        answer = "Sage data structures:" + chr(10) + "  let arr = [1, 2, 3]     # Array (dynamic)" + chr(10) + "  push(arr, 4)             # Append" + chr(10) + "  pop(arr)                 # Remove last" + chr(10) + "  print arr[0:2]           # Slicing -> [1, 2]" + chr(10) + "  let d = {}               # Dict (hash map)" + chr(10) + "  d[key] = value           # Set entry" + chr(10) + chr(10) + "  Libraries: import arrays, import dicts, import strings" + chr(10) + "  NOTE: No multiline literals. Build incrementally."
    if topic == "functions":
        answer = "Sage functions:" + chr(10) + "  proc greet(name):" + chr(10) + "      return name" + chr(10) + chr(10) + "  # Closures capture by reference:" + chr(10) + "  proc make_counter():" + chr(10) + "      let n = 0" + chr(10) + "      proc inc():" + chr(10) + "          n = n + 1" + chr(10) + "          return n" + chr(10) + "      return inc" + chr(10) + chr(10) + "  # Async:" + chr(10) + "  async proc fetch_data():" + chr(10) + "      let result = await do_io()" + chr(10) + "      return result"
    if topic == "errors":
        answer = "Sage exception handling:" + chr(10) + "  try:" + chr(10) + "      let result = risky_operation()" + chr(10) + "  catch e:" + chr(10) + "      print e  # error message string" + chr(10) + "  finally:" + chr(10) + "      cleanup()" + chr(10) + chr(10) + "  raise custom_error_message  # throw an error"
    if topic == "testing":
        answer = "Sage testing:" + chr(10) + "  bash tests/run_tests.sh   # 241 interpreter tests" + chr(10) + "  make test                 # 28 compiler tests" + chr(10) + "  make test-selfhost        # 1567+ self-hosted tests" + chr(10) + "  make test-all             # Everything" + chr(10) + chr(10) + "  import std.testing  # Test framework:" + chr(10) + "    testing.assert_eq(a, b)" + chr(10) + "    testing.assert_true(cond)" + chr(10) + chr(10) + "  Debug tips:" + chr(10) + "    - gc_disable() for GC segfaults" + chr(10) + "    - chr(10) not escape sequences" + chr(10) + "    - Avoid 5+ elif branches"
    if topic == "concurrency":
        answer = "Sage concurrency primitives:" + chr(10) + "  import thread          # OS threads + mutexes" + chr(10) + "  import std.channel     # Go-style buffered/unbuffered channels" + chr(10) + "  import std.atomic      # Atomic operations" + chr(10) + "  import std.rwlock      # Read-write locks" + chr(10) + "  import std.condvar     # Condition variables" + chr(10) + "  import std.threadpool  # Worker thread pools" + chr(10) + chr(10) + "  async proc work():  # Async/await syntax" + chr(10) + "      let result = await fetch()" + chr(10) + "      return result"
    if topic == "planning":
        push(chain["steps"], {"type": "plan", "content": "Breaking down into actionable steps"})
        answer = "Development plan:" + chr(10) + "  1. Define the feature scope and requirements" + chr(10) + "  2. Create module file in lib/<category>/name.sage" + chr(10) + "  3. Start with gc_disable() if heavy allocation needed" + chr(10) + "  4. Write implementation (procs, classes)" + chr(10) + "  5. Add test in tests/26_stdlib/" + chr(10) + "  6. Update Makefile install section for new files" + chr(10) + "  7. Update README.md and documentation/" + chr(10) + "  8. Run: make test-all"
    if topic == "syntax":
        answer = "Sage syntax basics:" + chr(10) + "  - Indentation-based (like Python), no braces/semicolons" + chr(10) + "  - let for variables: let x = 42" + chr(10) + "  - proc for functions: proc foo(a, b): return a + b" + chr(10) + "  - class for OOP: class Foo: proc init(self): ..." + chr(10) + "  - if/elif/else, for/while/break/continue, try/catch/finally" + chr(10) + "  - import for modules: import os.fat" + chr(10) + chr(10) + "  Reserved: match, and, or, not, nil, true, false"
    if topic == "string":
        answer = "Sage strings:" + chr(10) + "  let s = hello" + chr(10) + "  len(s)           # length" + chr(10) + "  s[0]             # indexing" + chr(10) + "  s + world        # concatenation" + chr(10) + "  split(s, delimiter)  # split to array" + chr(10) + "  join(arr, sep)       # join array" + chr(10) + chr(10) + "  No escape sequences! Use chr(10) for newline." + chr(10) + "  import std.fmt for advanced formatting." + chr(10) + "  import std.unicode for Unicode support."
    if topic == "io":
        answer = "Sage I/O:" + chr(10) + "  print value           # Print to stdout" + chr(10) + "  let s = input(prompt) # Read from stdin" + chr(10) + chr(10) + "  import io" + chr(10) + "  io.readfile(path)     # Read entire file to string" + chr(10) + "  io.writefile(path, s) # Write string to file" + chr(10) + chr(10) + "  NOTE: C io module uses readfile/writefile, not read/write."
    if len(answer) == 0:
        if len(mem_results) > 0:
            answer = "Based on my knowledge: " + mem_results[0]["entry"]["content"]
        else:
            answer = "I can help with: loops, imports, classes, GC, compiler, data structures, functions, errors, testing, concurrency, LLM, agents, crypto, networking, GPU, ML, OS, regex, strings, I/O, planning, and syntax. What would you like to know?"

    push(chain["steps"], {"type": "answer", "content": "Answering about " + topic})
    chain["conclusion"] = answer
    # Store in episodic memory
    engram.store_episodic(memory, "Answered about " + topic + ": " + question, 0.6)
    return chain

proc sage_llm(prompt):
    let chain = reason(prompt)
    return chain["conclusion"]

# Bot setup with SageDev persona
let b = bot.create("", "", sage_llm)
persona.apply_persona(b, persona.sage_developer())

proc on_greet(msg, conv):
    return "Hello! I am SageDev v2.0 — a SageGPT-Medium chatbot with 344544 parameters." + chr(10) + "I have chain-of-thought reasoning, 4-tier Engram memory, semantic routing, and deep knowledge" + chr(10) + "of the entire Sage codebase (137 source files). Ask me anything!"
proc on_bye(msg, conv):
    engram.consolidate(memory)
    return "Goodbye! Consolidated " + str(len(memory["semantic"])) + " memories. Happy coding!"

bot.add_intent(b, "greet", ["hello", "hi", "hey", "greetings"], on_greet)
bot.add_intent(b, "bye", ["bye", "quit", "exit", "goodbye"], on_bye)

let store = session.create_store()
let sess = session.new_session(store, "SageDev")

print "================================================================"
print "  SageLLM Chatbot v2.0.0 (SageGPT-Medium)"
print "  344544 params | 2 layers | 4096 context"
print "  CoT + Engram + RAG + Semantic Routing + Planning"
print "================================================================"
print bot.greet(b)
print "Commands: quit, memory, think <q>, plan <goal>, stats, history, search <q>"
print ""

let running = true
let turn_count = 0
while running:
    let msg = input("You> ")
    if msg == "quit" or msg == "exit":
        running = false
        print bot.farewell(b)
    if running and msg == "memory":
        print engram.summary(memory)
    if running and msg == "stats":
        print "Model: SageGPT-Medium (344544 params)"
        print "Turns: " + str(turn_count)
        print engram.summary(memory)
    if running and msg == "history":
        print session.export_text(sess)
    # search command
    if running and startswith_str(msg, "search "):
        let sq = substr(msg, 7)
        let results = engram.recall(memory, sq, 5)
        print ""
        print "Search results for: " + sq
        for si in range(len(results)):
            print "  " + str(si + 1) + ". " + results[si]["entry"]["content"]
        print ""
    # think command (show reasoning chain)
    if running and startswith_str(msg, "think "):
        let q = substr(msg, 6)
        let chain = reason(q)
        print ""
        print chain_to_string(chain)
        print ""
    # plan command
    if running and startswith_str(msg, "plan "):
        let goal = substr(msg, 5)
        let plan = planner.create_plan(goal)
        planner.add_step(plan, "Analyze requirements", "", "", nil)
        planner.add_step(plan, "Design architecture", "", "", [0])
        planner.add_step(plan, "Create module files", "", "", [1])
        planner.add_step(plan, "Write implementation", "", "", [2])
        planner.add_step(plan, "Write tests", "", "", [3])
        planner.add_step(plan, "Update documentation", "", "", [4])
        planner.add_step(plan, "Run test suite", "", "", [5])
        print ""
        print planner.format_plan(plan)
        engram.store_episodic(memory, "Created plan for: " + goal, 0.8)
        print ""
    # Normal conversation
    if running and msg != "quit" and msg != "exit" and msg != "memory" and msg != "stats" and msg != "history":
        let is_cmd = false
        if startswith_str(msg, "think "):
            is_cmd = true
        if startswith_str(msg, "plan "):
            is_cmd = true
        if startswith_str(msg, "search "):
            is_cmd = true
        if not is_cmd:
            engram.store_working(memory, msg, 0.7)
            let resp = bot.respond(b, msg)
            print ""
            print "SageDev> " + resp
            print ""
            session.add_turn(sess, msg, resp)
            turn_count = turn_count + 1
